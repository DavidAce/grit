#include <grit/grit.h>
#include <grit/internal/Matvec.ipp>
#include <grit/internal/solver_view.ipp>
#include <grit/internal/form/base.ipp>
#include <grit/internal/form/base_orth.ipp>
#include <grit/internal/form/base_ritz.ipp>
