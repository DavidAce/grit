#include <grit/internal/algo/gdplusk_correction.ipp>
#include <grit/internal/algo/lanczos.ipp>
#include <grit/internal/algo/lobpcg.ipp>

using Scalar = @SCALAR@;

template class grit::Matvec<Scalar>;
template grit::Matvec<Scalar> grit::matvec<Scalar>(Eigen::Index, typename grit::Matvec<Scalar>::MultFunc);
template grit::Matvec<Scalar> grit::matvec<Scalar>(Eigen::Index, grit::ptr_t, typename grit::Matvec<Scalar>::PtrMultFunc);
template class grit::solver_view<Scalar>;
template grit::solver_view<Scalar>::solver_view(const grit::form::base<Scalar, grit::Form::STANDARD> &);
template grit::solver_view<Scalar>::solver_view(const grit::form::base<Scalar, grit::Form::GENERALIZED> &);
template class grit::form::base<Scalar, grit::Form::STANDARD>;
template class grit::form::base<Scalar, grit::Form::GENERALIZED>;
template class grit::algo::gdplusk<Scalar, grit::Form::STANDARD>;
template class grit::algo::gdplusk<Scalar, grit::Form::GENERALIZED>;
template class grit::algo::lanczos<Scalar, grit::Form::STANDARD>;
template class grit::algo::lanczos<Scalar, grit::Form::GENERALIZED>;
template class grit::algo::lobpcg<Scalar, grit::Form::STANDARD>;
template class grit::algo::lobpcg<Scalar, grit::Form::GENERALIZED>;
